        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    var total = 6;
    var completed = 0;

    if (current.university_email_created == true) completed++;
    if (current.id_card_requested == true) completed++;
    if (current.hostel_allocated == true) completed++;
    if (current.transport_allocated == true) completed++;
    if (current.library_access_activated == true) completed++;
    if (current.enrollment_number != '') completed++;

    var progress = Math.round((completed / total) * 100);
    current.overall_progress = progress;

    if (progress == 0) {
        current.onboarding_status = 'not_started';
    } else if (progress == 100) {
        current.onboarding_status = 'completed';
    } else {
        current.onboarding_status = 'in_progress';
    }

})(current, previous);]]></script>
